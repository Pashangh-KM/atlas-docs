  "paths": {
    "/v1/docstream/authtoken": {
      "post": {
        "tags": ["v1"],
        "description": "Accepts Client-ID and Client-Secret in headers to generate a JWT access token.",
        "operationId": "generateToken",
        "parameters": [
          {
            "in": "header",
            "name": "Client-Id",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "Client ID provided to the application"
          },
          {
            "in": "header",
            "name": "Client-Secret",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "Client Secret associated with the client ID"
          }
        ],
        "responses": {
          "201": {
            "description": "JWT token generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    },
                    "expires_in": {
                      "type": "integer",
                      "example": 3600
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing Client-Id or Client-Secret",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Missing Client-Id or Client-Secret"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid Client-Id or Client-Secret",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Invalid Client-Id or Client-Secret"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/docstream/multiupload": {
      "post": {
        "tags": ["v1"],
        "description": "API to upload multiple file URLs for verification processing.",
        "operationId": "Multiupload",
        "parameters": [
          {
            "in": "header",
            "name": "Token",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "JWT token used for authentication"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "product_type": {
                    "type": "string",
                    "description": "Product Type",
                    "enum": ["PFL_POC"]
                  },
                  "file_urls": {
                    "type": "array",
                    "description": "List of file objects containing S3 URLs and metadata",
                    "items": {
                      "type": "object",
                      "properties": {
                        "file_url": {
                          "type": "string",
                          "format": "uri",
                          "description": "S3 URL of the file"
                        },
                        "document_id": {
                          "type": "string",
                          "description": "External document ID for tracking"
                        }
                      },
                      "required": ["file_url", "document_id"]
                    }
                  }
                },
                "required": ["file_urls", "product_type"],
                "example": {
                  "product_type": "PFL_POC",
                  "file_urls": [
                    {
                      "file_url": "https://files.s3.ap-south-1.amazonaws.com/uploads/files/sample1.jpg?response-content-disposition=inlin",
                      "document_id": "1"
                    },
                    {
                      "file_url": "https://files.s3.ap-south-1.amazonaws.com/uploads/files/sample1.jpg?response-content-disposition=inlin",
                      "document_id": "2"
                    },
                    {
                      "file_url": "https://files.s3.ap-south-1.amazonaws.com/uploads/files/sample1.jpg?response-content-disposition=inlin",
                      "document_id": "3"
                    }
                  ]
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Returns a batch Id for urls",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "items": {
                    "type": "object",
                    "properties": {
                      "batch_id": {
                        "type": "string",
                        "example": "BATCH-55193-DRTYJ-20250811084615"
                      },
                    },
                  },
                  "example": 
                    {
                      "batch_id": "BATCH-30732-SIYKJ-20251121113228",
                    }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Missing or empty required parameters: "
                    }
                  }
                }
              }
            }
          },
        }
      }
    },
   "/v1/docstream/extracts": {
  "get": {
    "tags": ["v1"],
    "description": "API to fetch extracted document data for a given batch.",
    "operationId": "DocstreamExtracts",
    "parameters": [
      {
        "in": "header",
        "name": "Token",
        "schema": {
          "type": "string"
        },
        "required": true,
        "description": "JWT token used for authentication"
      },
      {
        "in": "query",
        "name": "batch_id",
        "schema": {
          "type": "string"
        },
        "required": true,
        "description": "Batch ID for which extracted data should be returned",
        "example": "BATCH-69469-BBRSS-20260309081408"
      },
      {
        "in": "query",
        "name": "page",
        "schema": {
          "type": "integer",
          "default": 1
        },
        "required": false,
        "description": "Page number for pagination"
      },
      {
        "in": "query",
        "name": "per_page",
        "schema": {
          "type": "integer",
          "default": 50
        },
        "required": false,
        "description": "Number of records per page"
      }
    ],
    "responses": {
      "200": {
        "description": "Paginated list of extracted documents",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "data": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "document_id": {
                        "type": "string",
                        "example": "1"
                      },
                      "file_data": {
                        "type": "object",
                        "description": "Extracted document fields",
                        "example": {
                          "document_type": "AADHAAR",
                          "name": {
                            "value": "Yarlagadda Vijaya Lakshmi",
                            "confidence_score": 1.0
                          },
                          "date_of_birth": {
                            "value": "16/04/1983",
                            "confidence_score": 1.0
                          },
                          "address": {
                            "value": "W/O: Yarlagadda Siva Rama Krishna...",
                            "confidence_score": 1.0
                          }
                        }
                      }
                    },
                    "required": ["document_id", "file_data"]
                  }
                },
                "page": {
                  "type": "integer",
                  "example": 1
                },
                "per_page": {
                  "type": "integer",
                  "example": 50
                },
                "total_pages": {
                  "type": "integer",
                  "example": 1
                },
                "total_items": {
                  "type": "integer",
                  "example": 5
                },
                "has_next": {
                  "type": "boolean",
                  "example": false
                },
                "has_prev": {
                  "type": "boolean",
                  "example": false
                }
              }
            }
          }
        }
      },
      "400": {
        "description": "Bad Request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "batch_id is required"
                }
              }
            }
          }
        }
      },
      "401": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Invalid or expired token"
                }
              }
            }
          }
        }
      }
    }
  }
}
  }
}
