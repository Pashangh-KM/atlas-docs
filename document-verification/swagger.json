  },
  "paths": {
    "/v3/verification/authtoken": {
      "post": {
        "tags": ["v3"],
        "summary": "Generate JWT Token",
        "description": "Accepts Client-ID and Client-Secret in headers to generate a JWT access token.",
        "operationId": "generateToken",
        "parameters": [
          {
            "in": "header",
            "name": "Client-Id",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "Client ID provided to the application"
          },
          {
            "in": "header",
            "name": "Client-Secret",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "Client Secret associated with the client ID"
          }
        ],
        "responses": {
          "201": {
            "description": "JWT token generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    },
                    "expires_in": {
                      "type": "integer",
                      "example": 3600
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing Client-Id or Client-Secret",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Missing Client-Id or Client-Secret"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid Client-Id or Client-Secret",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Invalid Client-Id or Client-Secret"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v3/verification/multiupload": {
      "post": {
        "tags": ["v3"],
        "description": "API to upload multiple file URLs for verification processing.",
        "operationId": "Multiupload",
        "parameters": [
          {
            "in": "header",
            "name": "Token",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "JWT token used for authentication"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "flow_uuid": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Flow UUID associated with the verification request"
                  },
                  "file_urls": {
                    "type": "array",
                    "description": "List of file objects containing S3 URLs and metadata",
                    "items": {
                      "type": "object",
                      "properties": {
                        "file_url": {
                          "type": "string",
                          "format": "uri",
                          "description": "S3 URL of the file"
                        },
                        "document_id": {
                          "type": "string",
                          "description": "External document ID for tracking"
                        }
                      },
                      "required": ["file_url", "document_id"]
                    }
                  }
                },
                "required": ["flow_uuid", "file_urls"],
                "example": {
                  "flow_uuid": "LOS-17cab13b-f437-49bc-9c08-55319b88b0eb",
                  "file_urls": [
                    {
                      "file_url": "https://files.s3.ap-south-1.amazonaws.com/uploads/files/sample1.jpg?response-content-disposition=inlin",
                      "document_id": "1"
                    },
                    {
                      "file_url": "https://files.s3.ap-south-1.amazonaws.com/uploads/files/sample1.jpg?response-content-disposition=inlin",
                      "document_id": "2"
                    },
                    {
                      "file_url": "https://files.s3.ap-south-1.amazonaws.com/uploads/files/sample1.jpg?response-content-disposition=inlin",
                      "document_id": "3"
                    }
                  ]
                }
              }
            }
          }
        },
        "responses": {
           "201": {
            "description": "Batch ID generated for the uploaded files",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "batch_id": {
                      "type": "string",
                      "example": "BATCH-55193-DRTYJ-20250811084615"
                    }
                  },
                  "required": ["batch_id"],
                  "example": {
                    "batch_id": "BATCH-30732-SIYKJ-20251121113228"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Missing or empty required parameters: ['flow_uuid']"
                    }
                  }
                }
              }
            }
          },
        }
      }
    },
    "/v3/verification/flow/init": {
      "post": {
        "tags": ["v3"],
        "description": "Creates a flow for a given application and product type.",
        "operationId": "Flowinit",
        "parameters": [
          {
            "in": "header",
            "name": "Token",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "Access token"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "product_type",
                  "application_id",
                  "auth_url",
                  "callback_url"
                ],
                "properties": {
                  "product_type": {
                    "type": "string",
                    "description": "Product Type",
                    "enum": ["PFL_CDL"]
                  },
                  "application_id": {
                    "type": "string",
                    "description": "Application ID"
                  },
                  "auth_url": {
                    "type": "string",
                    "description": "Auth URL provided by the client",
                    "format": "uri"
                },
                  "callback_url": {
                    "type": "string",
                    "description": "Callback URL provided by the client",
                    "format": "uri"
                  },
                  "flow_params": {
                    "type": "object",
                    "description": "Optional flow parameters",
                    "additionalProperties": true
                  }
                },
                "example": {
                  "product_type": "PFL_CDL",
                  "application_id": "12321321",
                  "auth_url": "https://6964365893556.serviceurl.in/express-journey/core/auth-token",
                  "callback_url": "https://6964365893556.serviceurl.in/express-journey/core/v2/atlas/callback",
                  "flow_params": {}
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "flow_uuid": {
                      "type": "string",
                      "format": "uuid",
                      "example": "ec57821d-d766-4e24-81ef-a2768094511b"
                    }
                  },
                  "required": ["flow_uuid"],
                  "example": {
                    "flow_uuid": "ec57821d-d766-4e24-81ef-a2768094511b"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Invalid token"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Missing or empty required parameters: ['application_id']"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v3/verification/status": {
      "get": {
        "tags": ["v3"],
        "description": "API to fetch status for a given flow.",
        "operationId": "Status",
        "parameters": [
          {
            "in": "header",
            "name": "Token",
            "schema": {
              "type": "string"
            },
            "required": true,
            "description": "Access token"
          },
          {
            "in": "query",
            "name": "flow_uuid",
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "description": "UUID of the flow"
          }
        ],
        "responses": {
          "200": {
            "description": "Status response for all files and the master status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "upload_status": {
                      "type": "string",
                      "description": "Overall master status based on file statuses",
                      "enum": ["NOT_STARTED", "FAILED", "IN_PROGRESS", "SUCCESS"],
                      "example": "NOT_STARTED"
                    },
                    "processing_status": {
                      "type": "string",
                      "description": "Overall master status based on file statuses",
                      "enum": ["NOT_STARTED", "FAILED", "IN_PROGRESS", "SUCCESS", "PENDING"],
                      "example": "IN_PROGRESS"
                    },
                    "crossheck_status": {
                      "type": "string",
                      "description": "Overall master status based on file statuses",
                      "enum": ["NOT_STARTED", "COMPLETED", "PENDING"],
                      "example": "PENDING"
                    },
                    "master_status": {
                      "type": "string",
                      "description": "Overall status",
                      "enum": ["NOT_STARTED", "FAILED", "IN_PROGRESS", "SUCCESS"],
                      "example": "SUCCESS"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request - Missing or invalid parameters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Missing required ['flow_uuid'] parameters",
                      "description": "The client did not provide a required query parameter."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing token",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Invalid token",
                      "description": "Authentication token is invalid or expired"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Flow not found with provided flow_uuid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Flow not found"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v3/verification/extracts": {
  "get": {
    "tags": ["v3"],
    "description": "API to fetch processed verification results including OCR data and cross-check comparisons for a given flow.",
    "operationId": "ProcessedVerificationResults",
    "parameters": [
      {
        "in": "header",
        "name": "Token",
        "schema": {
          "type": "string"
        },
        "required": true,
        "description": "Access token"
      },
      {
        "in": "query",
        "name": "flow_uuid",
        "schema": {
          "type": "string",
          "format": "uuid"
        },
        "required": true,
        "description": "UUID of the flow whose verification result is requested"
      }
    ],
    "responses": {
      "200": {
        "description": "Verification processed results for all documents in the flow",
        "content": {
          "application/json": {
            "schema": {"$ref": "#/components/schemas/CallbackData"},
          }
        }
      },
      "400": {
        "description": "Bad Request - Missing or invalid parameters",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Missing required ['flow_uuid'] parameters"
                }
              }
            }
          }
        }
      },
      "401": {
        "description": "Unauthorized - Invalid or missing token",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Invalid token"
                }
              }
            }
          }
        }
      },
      "409": {
        "description": "Flow not found",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Flow not found"
                }
              }
            }
          }
        }
      }
    }
  }
}


  }
}
